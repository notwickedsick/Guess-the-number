import random
def main():
    while True:
        playgame()
        again = input("Do you want to play again? (y/n): ").lower()
        if again != "y":
            print("👋")
            break

def playgame():
    attempt = 5
    guess_list = []
    r1 = random.randint(1,20)
    print("Guess a number between 1-20")

    for i in range(5):
        
        guessnumber = int(input(f"You have {attempt} tries: "))    
        guess_list.append(guessnumber)
        if len(guess_list) == 1 and guessnumber == r1:
            print(f"You guessed the number {r1} on your first try🧐")
            break
        elif guessnumber == r1:
            print("✅")
            print(f"You guessed the number {r1}. Your guesses were: {', '.join(map(str, guess_list))}")
            break
        else:
            for i in range(1):
                attempt = attempt - 1
                #print(f"You have {attempt} tries left")
                if attempt == 0:
                    print(f"You did not guess the number☹️. The number was {r1}. Your guesses were: {', '.join(map(str, guess_list))}")
                    break

main()
